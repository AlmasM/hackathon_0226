{
  "framework": null,
  "buildCommand": "npm install && npm run build:frontend",
  "outputDirectory": "apps/frontend/dist",
  "functions": {
    "apps/backend/api/index.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/apps/backend/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/apps/backend/api/index.py"
    }
  ]
}
